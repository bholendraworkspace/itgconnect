rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper ───────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    // ── Employees ────────────────────────────────────────────────────────────
    // Any authenticated user can read all employees.
    // Create: any authenticated user (needed for auto-create on first login + seeding).
    // Update: only the document owner (uid == docId) can update their own profile.
    match /employees/{employeeId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && request.auth.uid == employeeId;
      allow delete: if false;
    }

    // ── Achievements ─────────────────────────────────────────────────────────
    match /achievements/{achievementId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if false;
    }

    // ── Recognitions ─────────────────────────────────────────────────────────
    match /recognitions/{recognitionId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if false;
      allow delete: if false;
    }

    // ── Ideas ────────────────────────────────────────────────────────────────
    // Any authenticated user can vote (update) or submit a new idea.
    match /ideas/{ideaId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if false;
    }

    // ── Events ───────────────────────────────────────────────────────────────
    // Any authenticated user can RSVP (update) or create an event.
    match /events/{eventId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if false;
    }

    // ── Special Announcements ────────────────────────────────────────────────
    match /specialAnnouncements/{announcementId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if false;
      allow delete: if false;
    }

    // ── News ─────────────────────────────────────────────────────────────────
    match /news/{newsId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if false;
    }

  }
}
