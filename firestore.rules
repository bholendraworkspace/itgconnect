rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper ───────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    // ── Employees ────────────────────────────────────────────────────────────
    match /employees/{employeeId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && request.auth.uid == employeeId;
      allow delete: if false;
    }

    // ── Achievements ─────────────────────────────────────────────────────────
    match /achievements/{achievementId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if false;
    }

    // ── Recognitions ─────────────────────────────────────────────────────────
    match /recognitions/{recognitionId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if false;
      allow delete: if false;
    }

    // ── Ideas ────────────────────────────────────────────────────────────────
    match /ideas/{ideaId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if false;
    }

    // ── Events ───────────────────────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if false;
    }

    // ── Special Announcements ────────────────────────────────────────────────
    match /specialAnnouncements/{announcementId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if false;
      allow delete: if false;
    }

    // ── News ─────────────────────────────────────────────────────────────────
    match /news/{newsId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if false;
    }

    // ── Feedback ─────────────────────────────────────────────────────────────
    match /feedback/{feedbackId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if false;
      allow delete: if false;
    }

    // ── API Projects (Postman-style collections) ──────────────────────────────
    // Any authenticated user can read, import, update and delete API collections.
    match /apiProjects/{projectId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth();
    }

  }
}
