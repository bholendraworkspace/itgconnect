rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper ───────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    // ── Employees ────────────────────────────────────────────────────────────
    match /employees/{employeeId} {
      allow read: if isAuth();
      allow create: if isAuth();
      // Allow users to update their own record (uid-based docs)
      // Also allow updates to seed employee docs (numeric IDs) for seeding
      allow update: if isAuth() && (request.auth.uid == employeeId || employeeId.matches('^[0-9]+$'));
      allow delete: if false;
    }

    // ── Achievements ─────────────────────────────────────────────────────────
    // Owner (employeeId stored in doc) can update/delete their achievements
    match /achievements/{achievementId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth();
    }

    // ── Recognitions ─────────────────────────────────────────────────────────
    // Sender (fromEmployeeId) can update/delete their recognitions
    match /recognitions/{recognitionId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth();
    }

    // ── Ideas ────────────────────────────────────────────────────────────────
    // Owner (employeeId) can update/delete; any auth user can vote (update)
    match /ideas/{ideaId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth();
    }

    // ── Events ───────────────────────────────────────────────────────────────
    // Organizer can update/delete; any auth user can RSVP (update)
    match /events/{eventId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth();
    }

    // ── Special Announcements ────────────────────────────────────────────────
    // Owner (employeeId) can update/delete their announcements
    match /specialAnnouncements/{announcementId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth();
    }

    // ── News ─────────────────────────────────────────────────────────────────
    match /news/{newsId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if false;
    }

    // ── Feedback ─────────────────────────────────────────────────────────────
    match /feedback/{feedbackId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if false;
      allow delete: if false;
    }

    // ── API Projects (Postman-style collections) ──────────────────────────────
    // Any authenticated user can read, import, update and delete API collections.
    match /apiProjects/{projectId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth();
    }

    // ── Meta (seed state tracking) ──────────────────────────────────────────
    match /_meta/{docId} {
      allow read, write: if isAuth();
    }

  }
}
